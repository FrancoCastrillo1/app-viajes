# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitees el .env a git.

# Flask — generá una clave aleatoria de al menos 32 chars:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar_por_clave_aleatoria_de_32_caracteres

# PostgreSQL (incluye sslmode si es Heroku/Railway/Render)
DATABASE_URL=postgresql://usuario:contrasena@host:5432/nombre_db

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Solo activar en desarrollo local, NUNCA en producción
FLASK_DEBUG=false

# Fase 2 — OAuth2 Google (obtener en console.cloud.google.com)
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
